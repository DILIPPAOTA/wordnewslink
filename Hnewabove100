<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Global News Hub</title>

<style>
body{
    margin:0;
    font-family:'Segoe UI';
    background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
    color:white;
}

.header{text-align:center;padding:20px;}

#search{
    width:60%;
    padding:12px;
    border-radius:25px;
    border:none;
}

.india{text-align:center;margin:20px;}

.india img{
    width:120px;
    animation:wave 2s infinite;
}

@keyframes wave{
    0%{transform:rotate(0);}
    50%{transform:rotate(5deg);}
    100%{transform:rotate(0);}
}

.ticker{
    overflow:hidden;
    white-space:nowrap;
    background:rgba(255,255,255,0.1);
    padding:12px;
    margin:10px 20px;
    border-radius:12px;
    backdrop-filter:blur(10px);
}

.track{
    display:inline-block;
    animation:scroll 120s linear infinite;
}

.ticker:hover .track{
    animation-play-state: paused;
}

.track span{
    margin-right:60px;
}

.new{
    background:red;
    padding:2px 6px;
    font-size:11px;
    margin-left:5px;
    border-radius:5px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
    gap:12px;
    padding:20px;
}

.card{
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(12px);
    padding:12px;
    border-radius:15px;
    text-align:center;
}

.card img{width:40px;}

@media(max-width:600px){
    #search{width:90%;}
    .grid{grid-template-columns:repeat(2,1fr);}
}

a{text-decoration:none;color:white;}

@keyframes scroll{
    0%{transform:translateX(100%)}
    100%{transform:translateX(-100%)}
}
</style>
</head>

<body>

<div class="header">
    <h1>🌍 ग्लोबल न्यूज़ हब</h1>
    <input type="text" id="search" placeholder="देश खोजें..." onkeyup="filterCountries()">
</div>

<div class="india">
    <a href="https://news.google.com/search?q=India&hl=hi&gl=IN&ceid=IN:hi" target="_blank">
        <img src="https://flagcdn.com/w320/in.png">
        <h2>🇮🇳 भारत की ताज़ा खबर</h2>
    </a>
</div>

<h2 style="text-align:center;">🔥 टॉप ताज़ा खबर</h2>
<div class="ticker">
    <div id="topTicker" class="track"></div>
</div>

<h2 style="text-align:center;">📰 अन्य खबरें</h2>
<div class="ticker">
    <div id="bottomTicker" class="track"></div>
</div>

<div class="grid" id="list"></div>

<script>

