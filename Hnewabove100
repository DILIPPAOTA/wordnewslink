["Uganda","ug"],["Ukraine","ua"],["United Arab Emirates","ae"],["United Kingdom","gb"],
["United States","us"],["Uruguay","uy"],["Uzbekistan","uz"],
["Vanuatu","vu"],["Vatican City","va"],["Venezuela","ve"],["Vietnam","vn"],
["Yemen","ye"],
["Zambia","zm"],["Zimbabwe","zw"]
];
let container=document.getElementById("list");

countries.forEach(c=>{
    let div=document.createElement("div");
    div.className="card";

    div.innerHTML=`
    <a href="https://news.google.com/search?q=${c[0]}&hl=hi&gl=IN&ceid=IN:hi" target="_blank">
        <img src="https://flagcdn.com/w40/${c[1]}.png">
        <br>${c[0]}
    </a>
    `;
    container.appendChild(div);
});

function filterCountries(){
    let input=document.getElementById("search").value.toLowerCase();
    let items=document.getElementsByClassName("card");

    for(let i=0;i<items.length;i++){
        let txt=items[i].innerText.toLowerCase();
        items[i].style.display=txt.includes(input)?"":"none";
    }
}

// 🔥 FIXED NEWS LOGIC
fetch("https://api.rss2json.com/v1/api.json?rss_url=https://news.google.com/rss?hl=hi&gl=IN&ceid=IN:hi")
.then(res=>res.json())
.then(data=>{

    let top=document.getElementById("topTicker");
    let bottom=document.getElementById("bottomTicker");

    let countTop = 0;

    data.items.forEach((n)=>{

        if(n.title.toLowerCase().includes("pakistan")) return;

        let html = `
        <a href="${n.link}" target="_blank">
        ${n.title}
        ${countTop < 3 ? '<span class="new">NEW</span>' : ''}
        </a>
        `;

        let span=document.createElement("span");
        span.innerHTML=html;

        // ✅ first 10 valid news go to top
        if(countTop < 10){
            top.appendChild(span);
            countTop++;
        }else{
            bottom.appendChild(span);
        }

    });

});
</script>

</body>
</html>
