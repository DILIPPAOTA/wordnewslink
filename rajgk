<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>राजस्थान ज्ञान सागर | लाइव टेस्ट</title>
    <style>
        body { font-family: 'Mangal', Arial; background: #f0f2f5; text-align: center; margin: 0; padding: 10px; }
        .container { max-width: 850px; margin: auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        
        /* टाइमर स्टाइल */
        #timer-box { 
            position: sticky; top: 0; z-index: 100;
            background: #d32f2f; color: white; padding: 10px; 
            font-size: 20px; font-weight: bold; border-radius: 5px; 
            margin-bottom: 15px; display: none;
        }

        .user-input-box { background: #e3f2fd; padding: 20px; border-radius: 10px; margin-bottom: 20px; }
        input { padding: 10px; border-radius: 5px; border: 1px solid #ccc; width: 80%; max-width: 300px; }

        .btn-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; }
        .subject-btn { padding: 15px; border: none; border-radius: 10px; color: white; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .rgk { background: #ff9800; } .hist { background: #795548; } .pol { background: #2196f3; } .comp { background: #9c27b0; } .hindi { background: #4caf50; }
        
        .quiz-section { display: none; text-align: left; }
        .question-card { background: #fff; border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 10px; border-left: 6px solid #d32f2f; }
        .options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
        .opt-btn { background: #f8f9fa; padding: 10px; border-radius: 5px; border: 1px solid #ccc; cursor: pointer; text-align: left; }
        
        .correct { background: #28a745 !important; color: white; }
        .wrong { background: #dc3545 !important; color: white; }
        
        .result-screen { display: none; padding: 40px; }
        .score-num { font-size: 48px; color: #d32f2f; font-weight: bold; }
    </style>
</head>
<body>

<div id="timer-box">⏳ समय शेष: <span id="time-left">25:00</span></div>

<div class="container" id="main-menu">
    <h1>🚩 "राजस्थान ज्ञान सागर: 5000+ वस्तुनिष्ठ प्रश्न" 🚩</h1>
    <div class="user-input-box">
        <label><b>परीक्षार्थी का नाम:</b></label><br><br>
        <input type="text" id="studentName" placeholder="अपना पूरा नाम लिखें...">
    </div>
    <p>विषय चुनें और 25 मिनट का टेस्ट शुरू करें:</p>
    <div class="btn-grid">
        <button class="subject-btn rgk" onclick="startQuiz('rajasthan')">राजस्थान GK</button>
        <button class="subject-btn hist" onclick="startQuiz('history')">इतिहास</button>
        <button class="subject-btn pol" onclick="startQuiz('polity')">राजनीति</button>
        <button class="subject-btn comp" onclick="startQuiz('computer')">कंप्यूटर</button>
        <button class="subject-btn hindi" onclick="startQuiz('hindi')">हिन्दी व्याकरण</button>
    </div>
</div>

<div class="container quiz-section" id="quiz-area">
    <div id="quiz-questions"></div>
    <button onclick="finishTest()" style="width:100%; padding:15px; background:#333; color:white; border:none; border-radius:10px; cursor:pointer; font-size:18px; margin-top:20px;">टेस्ट सबमिट करें</button>
</div>

<div class="container result-screen" id="result-area">
    <h2 id="congrats-msg"></h2>
    <p>आपका परिणाम:</p>
    <div class="score-num"><span id="user-score">0</span> / 25</div>
    <p id="time-taken-msg"></p>
    <button onclick="location.reload()" style="padding:12px 25px; background:#2196f3; color:white; border:none; border-radius:5px; cursor:pointer;">मुख्य मेनू पर जाएं</button>
</div>

